# FRED API 配置
FRED_API_KEY=your_fred_api_key_here

# 服务配置
SERVICE_PORT=8094
SERVICE_HOST=0.0.0.0

# 数据配置
DATA_DIR=./data
HISTORICAL_START_DATE=2000-01-01

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=1.0

# 阿里云市场 API（商品数据：黄金/白银/原油/铜）
# 在阿里云市场购买 alirmcom2 API 后，将 AppCode 填到下方
ALIRMCOM_APPCODE=
ALIRMCOM_BASE_URL=https://alirmcom2.market.alicloudapi.com
